rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function hasVerifiedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return hasVerifiedEmail()
        && request.auth.token.email == 'davidtencio@gmail.com';
    }

    function isOperator() {
      return hasVerifiedEmail()
        && request.auth.token.email in ['davidtencio@gmail.com', 'fhsvp2208@gmail.com'];
    }

    match /medicines/{id} {
      allow read: if isOperator();
      // El catálogo (crear/editar/eliminar) lo escribe solo el backend con el
      // Admin SDK, junto a su auditoría, de forma atómica. El cliente no puede.
      allow create, delete: if false;
      // Única excepción: el operador ajusta existencias y trazabilidad de lotes
      // desde la app (transacción de movimiento), nunca el resto de campos.
      allow update: if isOperator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'lots', 'lot', 'expiresAt'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;
    }
    match /pharmacists/{id} {
      allow read: if isOperator();
      // Altas/bajas/ediciones solo por el backend con el Admin SDK.
      allow create, update, delete: if false;
    }
    match /movements/{id} {
      allow read: if isOperator();
      allow create: if isOperator()
        && request.resource.data.actorEmail == request.auth.token.email;
      // Los movimientos son un registro de trazabilidad: no se editan ni borran.
      allow update, delete: if false;
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      // La bitácora la escribe solo el backend, en el mismo lote atómico que la
      // mutación que audita; así no puede omitirse ni falsificarse desde el cliente.
      allow create, update, delete: if false;
    }

    match /operationalEvents/{id} {
      allow read: if isAdmin();
      allow create: if isOperator()
        && request.resource.data.actorEmail == request.auth.token.email;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
