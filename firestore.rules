rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados (personal farmacéutico dado de alta en la
    // consola de Firebase) pueden leer o escribir el inventario.
    // Para endurecer a una lista blanca por correo, reemplace la condición por:
    //   allow read, write: if request.auth != null
    //     && request.auth.token.email in ['farmaceutico1@dominio', ...];
    match /medicines/{id} {
      allow read, write: if request.auth != null;
    }
    match /pharmacists/{id} {
      allow read, write: if request.auth != null;
    }
    match /movements/{id} {
      allow read, create: if request.auth != null;
      // Los movimientos son un registro de trazabilidad: no se editan ni borran.
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
